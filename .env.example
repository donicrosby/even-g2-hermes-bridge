# -- LiteLLM (required) --------------------------------------------------------
LITELLM_BASE_URL=https://litellm.local
LITELLM_API_KEY=sk-litellm-change-me
CHAT_MODEL=claude-sonnet-4

# -- BYOA auth (required) ------------------------------------------------------
# Token the glasses send as `Authorization: Bearer <BYOA_TOKEN>`.
# Set the same value in Even app → Settings → Add Agent → Token.
BYOA_TOKEN=change-me-to-a-long-random-string

# -- Bridge behavior -----------------------------------------------------------
SYSTEM_PROMPT=You are Hermes Agent, a helpful AI assistant accessible through Even Realities G2 smart glasses. Keep responses concise and natural.
MAX_HISTORY_TURNS=10
DEDUP_WINDOW_SECONDS=5

# -- Bridge host (Traefik routing) ---------------------------------------------
BRIDGE_HOST=hermes.local
TRAEFIK_CERTRESOLVER=smallstep

# -- TLS (optional — usually Terminated by Traefik) ----------------------------
# Set these only if the container terminates TLS itself.
# When unset, the container serves plaintext HTTP on port 8765
# and expects an upstream reverse proxy (Traefik, nginx, Caddy) to do HTTPS.
SSL_CERT_FILE=
SSL_KEY_FILE=

# -- Logging -------------------------------------------------------------------
LOG_LEVEL=INFO
