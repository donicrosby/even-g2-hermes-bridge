# -- LiteLLM -----------------------------------------------------------------------
LITELLM_BASE_URL=https://litellm.local:4000
WHISPER_MODEL=whisper-1
CHAT_MODEL=claude-sonnet-4

# -- Bridge Host -------------------------------------------------------------------
BRIDGE_HOST=hermes.local
TRAEFIK_CERTRESOLVER=smallstep

# -- Certs -------------------------------------------------------------------------
CERT_HOST_PATH=./certs
SSL_CA_FILE=/etc/hermes-bridge/certs/root_ca.crt
SSL_CERT_FILE=
SSL_KEY_FILE=

# -- VAD ---------------------------------------------------------------------------
VAD_AGGRESSIVENESS=3
SILENCE_FRAMES=30
MIN_SPEECH_FRAMES=5
LOOKBACK_FRAMES=10
MAX_HISTORY_TURNS=10

# -- Logging -----------------------------------------------------------------------
LOG_LEVEL=INFO
