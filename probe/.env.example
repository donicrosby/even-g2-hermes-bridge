# -- LiteLLM (required) --------------------------------------------------------
LITELLM_BASE_URL=https://litellm.local
LITELLM_API_KEY=sk-litellm-change-me
CHAT_MODEL=claude-sonnet-4
SYSTEM_PROMPT=You are a probe responder. Reply briefly.

# -- TLS (required — probe is HTTPS-only) --------------------------------------
# Server-side cert presented to the glasses. Use your local CA.
SSL_CERT_FILE=/etc/hermes-bridge/certs/server.crt
SSL_KEY_FILE=/etc/hermes-bridge/certs/server.key

# Upstream TLS: LiteLLM's cert is signed by your local CA, which is installed
# in the system trust store. `truststore.inject_into_ssl()` (called at startup)
# makes Python's ssl module use the system trust store, so httpx will trust
# LiteLLM without needing SSL_CA_FILE.

# -- Server --------------------------------------------------------------------
HOST=0.0.0.0
PORT=8765
LOG_LEVEL=INFO
