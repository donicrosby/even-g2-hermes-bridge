# -- Required ----------------------------------------------------------------
EVEN_G2_BRIDGE_TOKEN=change-me-to-a-long-random-string

# -- Network -----------------------------------------------------------------
# Bind host. 127.0.0.1 = loopback (Tailscale Serve or same-host reverse proxy).
# 0.0.0.0 = all interfaces (direct LAN or reverse proxy on a different host).
EVEN_G2_BRIDGE_HOST=127.0.0.1
EVEN_G2_BRIDGE_PORT=8767

# Network exposure mode: tailscale (auto-serve), reverse-proxy (user provides),
# or lan (direct bind, plaintext, dev only).
EVEN_G2_BRIDGE_NET=tailscale

# Explicit override for the externally-advertised WSS URL.
# If unset, the plugin auto-detects from Tailscale MagicDNS or LAN IP.
# Set this when running behind your own reverse proxy, e.g.:
#   EVEN_G2_BRIDGE_PUBLIC_URL=wss://hermes.example.com
EVEN_G2_BRIDGE_PUBLIC_URL=

# Tailscale Serve HTTPS port (only used when EVEN_G2_BRIDGE_NET=tailscale)
EVEN_G2_BRIDGE_SERVE_PORT=8443

# -- Voice ASR (LiteLLM Whisper, preferred when configured) ------------------
# When set, ASR runs via LiteLLM's /v1/audio/transcriptions endpoint.
# Point this at your whisper model on LiteLLM.
EVEN_G2_ASR_LITELLM_MODEL=whisper
EVEN_G2_ASR_LITELLM_BASE_URL=https://litellm.local
EVEN_G2_ASR_LITELLM_API_KEY=sk-litellm-change-me

# -- Voice ASR (faster-whisper CPU fallback, used if LiteLLM is unreachable) -
# Always available. Model name hardcoded to whisper-tiny for v1.

# -- Voice ASR (parakeet sidecar, macOS-only future path) --------------------
# EVEN_G2_ASR_SIDECAR_BIN=

# -- Access control (optional) -----------------------------------------------
# Comma-separated list of allowed user IDs. Empty = allow all.
EVEN_G2_ALLOWED_USERS=
EVEN_G2_ALLOW_ALL_USERS=1

# -- Cron delivery home channel (optional) -----------------------------------
# When set, "deliver=even_g2" cron jobs route to this chat ID.
# EVEN_G2_HOME_CHANNEL=
